#!/bin/bash

## Job Name
#PBS -N pth5_test_Transformer

## Project Funding Code
#PBS -P as_spms_cheongsa

## Queue Name
#PBS -q qamd_wfly

## Output and error files
#PBS -o pth5_test_transformer.out
#PBS -e pth5_test_transformer.err

## Walltime — 9 folds × up to 100 epochs on CPU; monitor first run to calibrate
#PBS -l walltime=48:00:00

## 1 CPU-only node, 1 cores, ~100GB memory for Intel HPC training
## ncpus must match NUM_CPUS in parameters.py (19).
#PBS -l select=1:ncpus=1:mem=100gb

## Load application environment (uncomment if conda is available on this node)
#module load anaconda2025/2025
#eval "$(/usr/local/anaconda2025/bin/conda shell.bash hook)"
#conda activate my-own-conda-env

## Capture number of allocated cores
NCPUS=${PBS_NP:-1}
echo "Using $NCPUS CPU cores on this node."

## OpenMP / BLAS threading for NumPy operations (extract_distance_matrices.py)
## These control MKL/OpenBLAS used by NumPy — separate from PyTorch's thread pool.
## PyTorch intra-op threads are set in Python via torch.set_num_threads()
## (see TORCH_NUM_THREADS in parameters.py).
export OMP_NUM_THREADS=$NCPUS
export MKL_NUM_THREADS=$NCPUS
export NUMEXPR_NUM_THREADS=$NCPUS
export OPENBLAS_NUM_THREADS=$NCPUS

## Change to the submission directory
echo $PBS_O_WORKDIR
cd $PBS_O_WORKDIR

## Use pyenv shell (session-scoped) rather than pyenv global (persists after job ends)
pyenv shell 3.13
poetry env use 3.13
#poetry run python main.py
cd test
poetry run python scratch.py --pth model_fold_5.pth --dm-pkl "../../Quasi_Differentiation_High_Temporal_Resolution_Cross_Correlations/Codes/Extract distance matrix (2017-2022) from pkl file/IQDw35.pkl"
